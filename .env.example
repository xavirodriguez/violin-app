# =============================================================================
# Feature Flags — Violin Mentor
# =============================================================================
# Each flag has a server-side and a NEXT_PUBLIC_ (client-side) version.
# Set to "true" to enable, "false" to disable.
# See FEATURE_FLAGS.md for full documentation.
# =============================================================================

# Offload audio processing to a Web Worker for 60Hz+ analysis.
# Risk: HIGH | Type: PERFORMANCE
FEATURE_AUDIO_WEB_WORKER=false
NEXT_PUBLIC_FEATURE_AUDIO_WEB_WORKER=false

# Real-time synchronization for group practice or teacher-led sessions.
# Risk: HIGH | Type: EXPERIMENTAL
FEATURE_SOCIAL_PRACTICE_ROOMS=false
NEXT_PUBLIC_FEATURE_SOCIAL_PRACTICE_ROOMS=false
